<div class="hd posts">
    <a href="/index.html"><i class="fa fa-home
 replay-btn" aria-hidden="true"></i></a>
    <div class="post-title">
        <p>
            <%= page.title %>
        </p>
        <hr>
    </div>
    <div class="post-content">
        <%- page.content %>
    </div>

    <!-- 章节导航 -->
<div class="chapter-nav" style="margin-top: 30px; display: flex; justify-content: space-between; border-top: 1px solid #000; padding-top: 15px;">
  <% if (page.prev) { %>
    <a href="<%- url_for(page.prev.path) %>" style="text-decoration: none; color: #000;">← <%= page.prev.title %></a>
  <% } else { %>
    <span style="color: #aaa;">已是第一章</span>
  <% } %>

  <% if (page.next) { %>
    <a href="<%- url_for(page.next.path) %>" style="text-decoration: none; color: #000;"><%= page.next.title %> →</a>
  <% } else { %>
    <span style="color: #aaa;">已是最后一章</span>
  <% } %>
</div>

    <% if (theme.valine.enable && page.comments) { %>
        <hr class="fhr">
        <div id="vcomments"></div>
    <% } %>
</div>